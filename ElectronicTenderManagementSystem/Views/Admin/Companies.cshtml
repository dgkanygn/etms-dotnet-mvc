@model IEnumerable<ETTS.Models.Domain.CompanyProfile>

@{
    ViewData["Title"] = "Şirket Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Kayıtlı Şirketler</h2>
</div>

<div class="card shadow">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Şirket Adı</th>
                        <th>E-posta</th>
                        <th>Telefon</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var company in Model)
                    {
                        <tr>
                            <td>@company.CompanyName</td>
                            <td>@company.User.Email</td>
                            <td>@company.Phone</td>
                            <td>
                                @if (company.IsActive)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group">
                                    <a asp-action="CompanyDetail" asp-route-id="@company.Id" class="btn btn-sm btn-info text-white">Detay</a>
                                    <form asp-action="ToggleCompany" asp-route-id="@company.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-sm @(company.IsActive ? "btn-warning" : "btn-success")">
                                            @(company.IsActive ? "Pasif Yap" : "Aktif Yap")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
