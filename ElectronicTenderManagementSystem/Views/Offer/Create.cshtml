@model ETTS.Models.ViewModels.OfferCreateViewModel

@{
    ViewData["Title"] = "Teklif Hazırla";
}

<div class="row justify-content-center animate-fade-in">
    <div class="col-lg-6">
        <div class="mb-4">
            <a asp-controller="OfferRequest" asp-action="Detail" asp-route-id="@Model.OfferRequestId" class="btn btn-link text-decoration-none p-0 text-secondary mb-3">
                <i class="bi bi-arrow-left me-1"></i> Geri Dön
            </a>
            <h2 class="display-6 fw-bold">Teklif Formu</h2>
            <p class="text-secondary">Aşağıdaki bilgileri eksiksiz doldurarak teklifinizi iletebilirsiniz.</p>
        </div>

        <div class="glass-card p-4 p-md-5">
            <div class="bg-primary bg-opacity-5 rounded-4 p-3 mb-4 border border-primary border-opacity-10 d-flex align-items-center">
                <i class="bi bi-info-circle-fill text-primary fs-4 me-3"></i>
                <div class="small">
                    <span class="text-secondary d-block">İlgili İhale:</span>
                    <span class="fw-bold">@Model.OfferRequestTitle</span>
                </div>
            </div>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="OfferRequestId" />
                <input type="hidden" asp-for="OfferRequestTitle" />
                
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="mb-4">
                    <label asp-for="Price" class="form-label fw-semibold text-dark"></label>
                    <div class="input-group input-group-lg shadow-sm">
                        <span class="input-group-text bg-white border-end-0 text-secondary">₺</span>
                        <input asp-for="Price" class="form-control border-start-0 ps-0 fw-bold" placeholder="0,00" />
                    </div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                
                <div class="mb-4">
                    <label asp-for="DeliveryDays" class="form-label fw-semibold text-dark"></label>
                    <div class="input-group shadow-sm">
                        <input asp-for="DeliveryDays" class="form-control" placeholder="Örn: 15" />
                        <span class="input-group-text bg-light">Gün</span>
                    </div>
                    <span asp-validation-for="DeliveryDays" class="text-danger small"></span>
                </div>
                
                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold text-dark"></label>
                    <textarea asp-for="Description" class="form-control shadow-sm" rows="4" placeholder="Teklif içeriği, şartlar ve diğer detayları buraya yazınız..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                
                <div class="mb-5">
                    <label asp-for="Document" class="form-label fw-semibold text-dark"></label>
                    <div class="p-4 border border-2 border-dashed rounded-4 text-center bg-light bg-opacity-50 position-relative">
                        <i class="bi bi-cloud-arrow-up display-5 text-secondary"></i>
                        <p class="mb-0 mt-2 small text-secondary">Dokümanı buraya sürükleyin veya <span class="text-primary fw-bold">dosya seçin</span></p>
                        <input asp-for="Document" type="file" class="form-control position-absolute top-0 start-0 w-100 h-100 opacity-0" style="cursor: pointer;" />
                    </div>
                    <small class="text-muted d-block mt-2"><i class="bi bi-info-circle me-1"></i> PDF, Word veya Excel dosyaları yüklenebilir.</small>
                    <span asp-validation-for="Document" class="text-danger small"></span>
                </div>
                
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg shadow">Teklifi Gönder</button>
                    <a asp-controller="OfferRequest" asp-action="Index" class="btn btn-link text-secondary text-decoration-none">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .border-dashed { border-style: dashed !important; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
