<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElectronicTenderManagementSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ElectronicTenderManagementSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-intersect me-2"></i>
                    ETTS
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3" asp-controller="OfferRequest" asp-action="Index">İhaleler</a>
                            </li>
                            @if (User.IsInRole("Company"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link px-3" asp-controller="Offer" asp-action="MyOffers">Tekliflerim</a>
                                </li>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link px-3 text-primary fw-bold" asp-controller="Admin" asp-action="Dashboard">Yönetim</a>
                                </li>
                            }
                        }
                    </ul>
                    <div class="d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <button class="btn btn-light dropdown-toggle d-flex align-items-center shadow-sm" type="button" id="userDropdown" data-bs-toggle="dropdown">
                                    <div class="bg-primary text-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                        @User.Identity.Name?[0].ToString().ToUpper()
                                    </div>
                                    <span class="d-none d-md-inline">@User.Identity.Name</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow mt-2">
                                    <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i>Profilim</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-link text-dark text-decoration-none me-2" asp-controller="Account" asp-action="Login">Giriş Yap</a>
                            <a class="btn btn-primary px-4 shadow-sm" asp-controller="Account" asp-action="Register">Hemen Kaydol</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="row gy-4">
                <div class="col-lg-4">
                    <a class="navbar-brand d-flex align-items-center text-white mb-3 text-decoration-none" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-intersect me-2 text-primary"></i>
                        <span class="fw-bold fs-4">ETTS</span>
                    </a>
                    <p class="text-secondary-emphasis">Türkiye'nin en modern ve şeffaf elektronik teklif toplama platformu. Şirketinizi geleceğe taşıyın.</p>
                </div>
                <div class="col-lg-2 offset-lg-2">
                    <h6 class="text-white mb-4 fw-bold text-uppercase small">Hızlı Linkler</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white">Hakkımızda</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white">Nasıl Çalışır?</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white">İletişim</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="text-white mb-4 fw-bold text-uppercase small">Bültene Abone Ol</h6>
                    <p class="small text-secondary mb-3">Güncel ihalelerden haberdar olmak için kaydolun.</p>
                    <form class="d-flex gap-2">
                        <input type="email" class="form-control bg-dark border-secondary text-white" placeholder="E-posta adresiniz">
                        <button class="btn btn-primary">Katıl</button>
                    </form>
                </div>
            </div>
            <hr class="mt-5 border-secondary opacity-25">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center pt-3 small">
                <p class="mb-0 text-secondary">&copy; @DateTime.Now.Year ETTS - Tüm hakları saklıdır.</p>
                <div class="d-flex gap-4 mt-3 mt-md-0">
                    <a href="#" class="text-secondary text-decoration-none hover-white">Gizlilik Politikası</a>
                    <a href="#" class="text-secondary text-decoration-none hover-white">Kullanım Şartları</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
