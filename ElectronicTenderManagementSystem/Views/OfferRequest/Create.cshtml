@model ETTS.Models.ViewModels.OfferRequestViewModel

@{
    ViewData["Title"] = "Yeni Teklif Talebi";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Yeni Teklif Talebi Oluştur</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" placeholder="Örn: 2025 Ofis Malzemeleri Alımı" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="İhtiyaç detaylarını buraya yazınız..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Deadline" class="form-label"></label>
                        <input asp-for="Deadline" type="date" class="form-control" min="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="Deadline" class="text-danger"></span>
                    </div>
                    
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                        <button type="submit" class="btn btn-primary">Talebi Yayınla</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
