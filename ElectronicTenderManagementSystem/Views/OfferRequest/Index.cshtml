@model IEnumerable<ETTS.Models.Domain.OfferRequest>

@{
    ViewData["Title"] = "Aktif İhaleler";
}

<div class="animate-fade-in">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
        <div>
            <h2 class="display-6 fw-bold mb-1">Teklif Talepleri</h2>
            <p class="text-secondary mb-0">Şu anda yayında olan tüm aktif ihaleleri inceleyebilirsiniz.</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="mt-3 mt-md-0">
                <a asp-action="Create" class="btn btn-primary d-flex align-items-center shadow-sm">
                    <i class="bi bi-plus-lg me-2"></i> Yeni Talep Oluştur
                </a>
            </div>
        }
    </div>

    <div class="row g-4">
        @foreach (var request in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="glass-card h-100 p-0 overflow-hidden d-flex flex-column">
                    <div class="p-4 flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title text-dark mb-0 pe-2">@request.Title</h5>
                            @{
                                var timeLeft = request.Deadline - DateTime.UtcNow;
                                var statusClass = timeLeft.TotalDays > 3 ? "bg-success" : (timeLeft.TotalDays > 0 ? "bg-warning text-dark" : "bg-danger text-white");
                                var statusText = timeLeft.TotalDays > 0 ? $"{(int)timeLeft.TotalDays} gün kaldı" : "Süresi Doldu";
                            }
                            <span class="badge @statusClass shadow-sm" style="font-size: 0.75rem;">@statusText</span>
                        </div>
                        <p class="text-secondary small mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; height: 4.5em;">
                            @request.Description
                        </p>
                        
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="bg-light rounded-2 p-2 px-3 d-flex align-items-center">
                                <i class="bi bi-calendar3 text-primary me-2"></i>
                                <span class="small fw-semibold">@request.Deadline.ToString("dd MMM yyyy")</span>
                            </div>
                            <div class="bg-light rounded-2 p-2 px-3 d-flex align-items-center">
                                <i class="bi bi-cash-stack text-success me-2"></i>
                                <span class="small fw-semibold">@request.Offers.Count Teklif</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-light bg-opacity-50 p-3 px-4 d-flex justify-content-between align-items-center border-top">
                        <a asp-action="Detail" asp-route-id="@request.Id" class="text-decoration-none fw-bold text-primary small">
                            İncele <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@request.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                        }
                        else if (timeLeft.TotalDays > 0 && User.IsInRole("Company"))
                        {
                             <a asp-controller="Offer" asp-action="Create" asp-route-requestId="@request.Id" class="btn btn-success btn-sm px-3 shadow-sm">
                                Teklif Ver
                             </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center p-4 mb-3">
                <i class="bi bi-inbox text-secondary display-4"></i>
            </div>
            <h4 class="text-secondary">Henüz bir talep bulunmuyor.</h4>
        </div>
    }
</div>
